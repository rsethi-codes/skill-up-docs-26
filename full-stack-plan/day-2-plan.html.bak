<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Day 2 — TypeScript Advanced + Async Patterns | Raghav's Roadmap</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=JetBrains+Mono:ital,wght@0,300;0,400;0,700;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f5f0e8;
  --bg2: #ede8de;
  --bg3: #e4ddd0;
  --ink: #1a1410;
  --ink2: #2d2520;
  --ink3: #453d35;
  --muted: #7a6f62;
  --muted2: #a89e92;
  --border: rgba(26,20,16,0.12);
  --border2: rgba(26,20,16,0.06);
  --rust: #c0392b;
  --rust2: #e74c3c;
  --rust-bg: rgba(192,57,43,0.07);
  --rust-border: rgba(192,57,43,0.2);
  --teal: #0d7f7f;
  --teal2: #0fb3b3;
  --teal-bg: rgba(13,127,127,0.07);
  --teal-border: rgba(13,127,127,0.2);
  --gold: #b8860b;
  --gold2: #d4a017;
  --gold-bg: rgba(184,134,11,0.08);
  --gold-border: rgba(184,134,11,0.22);
  --plum: #5b2d8e;
  --plum-bg: rgba(91,45,142,0.07);
  --plum-border: rgba(91,45,142,0.2);
  --green: #1a6b3c;
  --green-bg: rgba(26,107,60,0.07);
  --green-border: rgba(26,107,60,0.2);
  --serif: 'Playfair Display', Georgia, serif;
  --mono: 'JetBrains Mono', 'Fira Code', monospace;
  --sans: 'DM Sans', system-ui, sans-serif;
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}

body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--ink);
  line-height: 1.75;
  font-size: 16px;
  overflow-x: hidden;
}

body::after {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 9999; opacity: 0.6;
}

#prog {
  position: fixed; top: 0; left: 0; height: 3px; width: 0;
  background: linear-gradient(90deg, var(--teal), var(--plum), var(--gold));
  z-index: 1000; transition: width .1s linear;
  box-shadow: 0 0 10px rgba(13,127,127,0.5);
}

#top-btn {
  position: fixed; bottom: 28px; right: 28px; width: 42px; height: 42px;
  background: var(--ink2); color: #fff; border: none; border-radius: 6px;
  font-size: 18px; cursor: pointer; z-index: 900; opacity: 0; transition: opacity .3s, transform .2s;
  display: flex; align-items: center; justify-content: center;
}
#top-btn.show { opacity: 1; }
#top-btn:hover { transform: translateY(-2px); background: var(--rust); }

/* ─── TOPBAR ─── */
.topbar {
  position: fixed; top: 0; left: 0; right: 0; height: 54px;
  background: rgba(245,240,232,0.94); backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 28px; z-index: 900;
}
.tb-brand { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--teal); letter-spacing: .06em; }
.tb-day { font-family: var(--mono); font-size: 11px; color: var(--muted); }
.tb-nav { display: flex; gap: 22px; list-style: none; }
.tb-nav a { font-family: var(--sans); font-size: 12px; font-weight: 500; color: var(--muted); text-decoration: none; transition: color .2s; }
.tb-nav a:hover { color: var(--teal); }

/* ─── SIDEBAR ─── */
.sidebar {
  position: fixed; left: 0; top: 54px; width: 222px;
  height: calc(100vh - 54px); overflow-y: auto;
  padding: 24px 0; border-right: 1px solid var(--border);
  background: rgba(245,240,232,0.85); backdrop-filter: blur(12px);
  z-index: 800;
}
.sidebar::-webkit-scrollbar { width: 2px }
.sidebar::-webkit-scrollbar-thumb { background: var(--muted2); }
.toc-head {
  padding: 0 18px 12px; font-family: var(--mono); font-size: 9px;
  font-weight: 700; letter-spacing: .22em; text-transform: uppercase;
  color: var(--muted2); border-bottom: 1px solid var(--border); margin-bottom: 10px;
}
.toc-section {
  padding: 8px 18px 4px; font-family: var(--mono); font-size: 8px; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase; color: var(--muted2);
}
.toc-link {
  display: block; padding: 5px 18px; font-family: var(--sans); font-size: 12px;
  font-weight: 400; color: var(--muted); text-decoration: none;
  border-left: 2px solid transparent; transition: all .18s; line-height: 1.4;
}
.toc-link:hover, .toc-link.on { color: var(--teal); border-left-color: var(--teal); background: var(--teal-bg); }
.toc-link.sub { padding-left: 28px; font-size: 11px; }
.toc-link.sub:hover, .toc-link.sub.on { color: var(--plum); border-left-color: var(--plum); background: var(--plum-bg); }

/* ─── MAIN LAYOUT ─── */
.main { margin-left: 222px; padding-top: 54px; }
.content { max-width: 880px; margin: 0 auto; padding: 60px 44px 120px; }

/* ─── HERO ─── */
.hero { margin-bottom: 72px; padding-bottom: 60px; border-bottom: 2px solid var(--border); }
.day-pill {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--teal); color: #fff;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: .14em; text-transform: uppercase;
  padding: 4px 14px; border-radius: 2px; margin-bottom: 20px;
}
.day-pill::before {
  content: ''; width: 5px; height: 5px; background: rgba(255,255,255,0.8);
  border-radius: 50%; animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.6)} }

h1.hero-title {
  font-family: var(--serif); font-size: clamp(34px, 5.5vw, 60px);
  font-weight: 900; line-height: 1.0; letter-spacing: -.02em;
  color: var(--ink); margin-bottom: 18px;
}
h1.hero-title .accent { color: var(--teal); font-style: italic; }
h1.hero-title .accent2 { color: var(--plum); font-style: italic; }
.hero-lead {
  font-family: var(--sans); font-size: 17px; font-weight: 300;
  color: var(--ink3); max-width: 640px; line-height: 1.78; margin-bottom: 28px;
}
.hero-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.tag {
  font-family: var(--mono); font-size: 10px; padding: 3px 10px;
  border-radius: 2px; border: 1px solid; letter-spacing: .04em;
}
.tag.r { color: var(--rust); border-color: var(--rust-border); background: var(--rust-bg); }
.tag.t { color: var(--teal); border-color: var(--teal-border); background: var(--teal-bg); }
.tag.g { color: var(--gold); border-color: var(--gold-border); background: var(--gold-bg); }
.tag.p { color: var(--plum); border-color: var(--plum-border); background: var(--plum-bg); }
.tag.gr { color: var(--green); border-color: var(--green-border); background: var(--green-bg); }

/* ─── SECTIONS ─── */
.section { margin-bottom: 88px; scroll-margin-top: 74px; }
.section-number {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--muted2); margin-bottom: 4px;
  display: flex; align-items: center; gap: 12px;
}
.section-number::after { content: ''; flex: 1; height: 1px; background: var(--border); }

h2.sec-title {
  font-family: var(--serif); font-size: clamp(24px, 3vw, 38px);
  font-weight: 900; letter-spacing: -.01em; line-height: 1.1;
  color: var(--ink); margin-bottom: 14px;
}
h2.sec-title .accent { color: var(--teal); font-style: italic; }
h2.sec-title .accent2 { color: var(--plum); font-style: italic; }
h2.sec-title .accent3 { color: var(--rust); font-style: italic; }
.sec-lead { font-size: 15.5px; color: var(--ink3); max-width: 700px; margin-bottom: 40px; line-height: 1.82; }

.sub { margin-bottom: 56px; scroll-margin-top: 74px; }
h3.sub-title {
  font-family: var(--sans); font-size: 20px; font-weight: 600;
  color: var(--ink); margin-bottom: 16px;
  display: flex; align-items: center; gap: 10px;
}
h3.sub-title .sub-num {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  color: #fff; background: var(--teal); padding: 2px 8px; border-radius: 2px; flex-shrink: 0;
}
h3.sub-title .sub-num.p { background: var(--plum); }
h3.sub-title .sub-num.r { background: var(--rust); }
h3.sub-title .sub-num.g { background: var(--gold); }
h4.mini-title {
  font-family: var(--sans); font-size: 14px; font-weight: 700;
  color: var(--ink); margin: 26px 0 10px; letter-spacing: -.01em;
  display: flex; align-items: center; gap: 8px;
}
h4.mini-title::before { content: ''; width: 3px; height: 14px; background: var(--teal); border-radius: 2px; }

p { color: var(--ink3); line-height: 1.82; margin-bottom: 16px; font-size: 15.5px; }
p strong { color: var(--ink); font-weight: 600; }
p em { color: var(--teal); font-style: italic; }
p code {
  font-family: var(--mono); font-size: 13px; background: var(--bg3);
  padding: 2px 6px; border-radius: 3px; color: var(--ink); border: 1px solid var(--border);
}

ul.prose-list, ol.prose-list {
  margin: 14px 0 22px 22px; display: flex; flex-direction: column; gap: 8px;
}
ul.prose-list li, ol.prose-list li { color: var(--ink3); font-size: 15px; line-height: 1.72; }
ul.prose-list li strong { color: var(--ink); }
ul.prose-list li code, ol.prose-list li code {
  font-family: var(--mono); font-size: 12.5px; background: var(--bg3);
  padding: 1px 5px; border-radius: 3px; color: var(--ink); border: 1px solid var(--border);
}

/* ─── CALLOUTS ─── */
.callout { border-radius: 7px; padding: 18px 22px; margin: 24px 0; border-left: 3px solid; }
.callout-title {
  font-family: var(--mono); font-size: 9.5px; font-weight: 700;
  letter-spacing: .18em; text-transform: uppercase; margin-bottom: 9px;
}
.callout p { margin-bottom: 0; font-size: 14.5px; }
.callout.danger { background: var(--rust-bg); border-color: var(--rust); }
.callout.danger .callout-title { color: var(--rust); }
.callout.insight { background: var(--plum-bg); border-color: var(--plum); }
.callout.insight .callout-title { color: var(--plum); }
.callout.tip { background: var(--green-bg); border-color: var(--green); }
.callout.tip .callout-title { color: var(--green); }
.callout.warn { background: var(--gold-bg); border-color: var(--gold); }
.callout.warn .callout-title { color: var(--gold); }
.callout.info { background: var(--teal-bg); border-color: var(--teal); }
.callout.info .callout-title { color: var(--teal); }

/* ─── CODE BLOCKS ─── */
.code-block {
  border-radius: 9px; overflow: hidden; margin: 24px 0;
  border: 1px solid var(--border); box-shadow: 0 3px 16px rgba(0,0,0,.06);
}
.code-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 16px; background: #1c1612; border-bottom: 1px solid rgba(255,255,255,.05);
}
.code-lang { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--teal2); }
.code-label { font-family: var(--mono); font-size: 10px; color: rgba(255,255,255,.28); font-style: italic; }
.copy-btn {
  background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1);
  color: rgba(255,255,255,.4); font-family: var(--mono); font-size: 10px;
  padding: 3px 10px; border-radius: 3px; cursor: pointer; transition: all .2s;
}
.copy-btn:hover { background: var(--teal); color: #fff; border-color: var(--teal); }
pre {
  background: #181410; padding: 24px 26px; overflow-x: auto;
  font-family: var(--mono); font-size: 13px; line-height: 1.88;
}
pre::-webkit-scrollbar { height: 3px }
pre::-webkit-scrollbar-thumb { background: #3a3028; border-radius: 2px }
pre code { background: none; padding: 0; font-size: inherit; color: inherit; border: none; }

/* Syntax highlighting */
.kw  { color: #c678dd }
.fn  { color: #61afef }
.str { color: #98c379 }
.num { color: #d19a66 }
.cm  { color: #5c6370; font-style: italic }
.cl  { color: #e5c07b }
.var { color: #abb2bf }
.op  { color: #e06c75 }
.prop{ color: #61afef }
.at  { color: #e5c07b }
.type{ color: #e5c07b }
.dec { color: #e06c75 }
.pun { color: #abb2bf }
.iface{ color: #56b6c2 }

/* ─── BEFORE/AFTER ─── */
.ba {
  display: grid; grid-template-columns: 1fr 1fr; margin: 24px 0;
  border-radius: 9px; overflow: hidden; border: 1px solid var(--border);
  box-shadow: 0 3px 16px rgba(0,0,0,.06);
}
.ba-head {
  padding: 10px 16px; font-family: var(--mono); font-size: 10px;
  font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  display: flex; align-items: center; gap: 7px;
}
.ba-bad .ba-head { background: rgba(192,57,43,.1); color: var(--rust); border-bottom: 1px solid rgba(192,57,43,.15); }
.ba-good .ba-head { background: rgba(26,107,60,.08); color: var(--green); border-bottom: 1px solid rgba(26,107,60,.15); }
.ba-pane pre { border-radius: 0; font-size: 12.5px; padding: 20px; }

/* ─── DIAGRAMS ─── */
.diagram {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 9px; padding: 28px; margin: 24px 0; overflow-x: auto;
}
.diag-title {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase;
  color: var(--muted); text-align: center; margin-bottom: 24px;
}

/* ─── FLOW DIAGRAM ─── */
.flow {
  display: flex; align-items: stretch; gap: 0; margin: 24px 0; overflow-x: auto;
}
.flow-step {
  flex: 1; min-width: 130px; background: var(--bg2); border: 1px solid var(--border);
  border-radius: 0; padding: 16px 14px; position: relative; text-align: center;
}
.flow-step:first-child { border-radius: 7px 0 0 7px; }
.flow-step:last-child { border-radius: 0 7px 7px 0; }
.flow-step + .flow-step { border-left: none; }
.flow-step-num { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--muted2); margin-bottom: 6px; }
.flow-step-label { font-family: var(--sans); font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 5px; }
.flow-step-desc { font-size: 11.5px; color: var(--muted); line-height: 1.5; }
.flow-arrow { display: flex; align-items: center; padding: 0 6px; color: var(--muted2); font-size: 18px; }
.flow-step.active { border-color: var(--teal-border); background: var(--teal-bg); }
.flow-step.active .flow-step-label { color: var(--teal); }
.flow-step.error { border-color: var(--rust-border); background: var(--rust-bg); }
.flow-step.error .flow-step-label { color: var(--rust); }

/* ─── MENTAL MODEL ─── */
.mental-model {
  background: linear-gradient(135deg, rgba(13,127,127,0.06), rgba(91,45,142,0.06));
  border: 2px solid var(--teal-border); border-radius: 10px;
  padding: 28px 32px; margin: 28px 0;
}
.mental-model h4 {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase; color: var(--teal);
  margin-bottom: 14px;
}
.mental-model p { font-size: 16px; color: var(--ink); margin-bottom: 0; line-height: 1.78; }
.mental-model p strong { color: var(--teal); }

/* ─── CONFIG TABLE ─── */
.config-table {
  width: 100%; border-collapse: collapse; margin: 22px 0;
  border: 1px solid var(--border); border-radius: 9px; overflow: hidden; font-size: 13.5px;
}
.config-table th {
  background: var(--ink2); color: rgba(255,255,255,.65);
  font-family: var(--mono); font-size: 9.5px; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase; padding: 10px 16px; text-align: left;
}
.config-table td { padding: 12px 16px; border-top: 1px solid var(--border); vertical-align: top; color: var(--ink3); line-height: 1.6; }
.config-table td:first-child { font-family: var(--mono); font-size: 12px; color: var(--teal2); font-weight: 600; min-width: 170px; }
.config-table td code { font-family: var(--mono); font-size: 12px; background: var(--bg3); padding: 1px 5px; border-radius: 3px; border: 1px solid var(--border); }
.config-table tr:nth-child(even) td { background: rgba(0,0,0,0.015); }
.config-table td.required { color: var(--rust); font-weight: 700; font-size: 11px; font-family: var(--mono); letter-spacing: .08em; }
.config-table td.recommended { color: var(--teal); font-weight: 700; font-size: 11px; font-family: var(--mono); letter-spacing: .08em; }

/* ─── COMPARISON GRID ─── */
.comp-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 22px 0;
}
.comp-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 8px; padding: 20px;
}
.comp-card h4 { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 12px; }
.comp-card.teal h4 { color: var(--teal); }
.comp-card.plum h4 { color: var(--plum); }
.comp-card.rust h4 { color: var(--rust); }
.comp-card.gold h4 { color: var(--gold); }
.comp-card p { font-size: 13.5px; color: var(--ink3); margin-bottom: 8px; line-height: 1.65; }
.comp-card ul { margin-left: 16px; }
.comp-card ul li { font-size: 13px; color: var(--ink3); margin-bottom: 4px; }

/* ─── INLINE RESOURCE ─── */
.inline-res {
  display: flex; gap: 14px; padding: 14px 18px;
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 7px; margin: 18px 0; text-decoration: none;
  transition: all .2s; align-items: flex-start;
}
.inline-res:hover { border-color: var(--teal); background: var(--teal-bg); transform: translateX(3px); }
.ir-icon { font-size: 22px; flex-shrink: 0; margin-top: 2px; }
.ir-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--muted2); margin-bottom: 3px; }
.ir-title { font-family: var(--sans); font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 3px; }
.ir-desc { font-size: 12.5px; color: var(--muted); line-height: 1.55; }

/* ─── VIDEO ─── */
.video-wrap {
  margin: 28px 0; border-radius: 9px; overflow: hidden;
  border: 1px solid var(--border); box-shadow: 0 4px 22px rgba(0,0,0,.09);
}
.video-label {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 16px; background: #1c1612;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.45);
}
.video-label .vl-accent { color: var(--teal2); }
.video-wrap iframe { display: block; width: 100%; aspect-ratio: 16/9; border: none; }

/* ─── KNOWLEDGE CHECK ─── */
.check-grid { display: flex; flex-direction: column; gap: 14px; margin-top: 28px; }
.check-item {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 8px; overflow: hidden; transition: box-shadow .2s;
}
.check-item:hover { box-shadow: 0 4px 16px rgba(0,0,0,.06); }
.check-header { padding: 18px 22px; cursor: pointer; display: flex; align-items: flex-start; gap: 14px; }
.check-q {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: .14em; text-transform: uppercase; color: var(--teal);
  flex-shrink: 0; padding-top: 2px;
}
.check-text { font-size: 14.5px; color: var(--ink); font-weight: 500; line-height: 1.6; flex: 1; }
.check-toggle { font-family: var(--mono); font-size: 18px; color: var(--muted2); flex-shrink: 0; transition: transform .2s; line-height: 1; padding-top: 2px; }
.check-reveal {
  padding: 18px 22px; border-top: 1px solid var(--border);
  background: var(--bg3); display: none;
  font-size: 14px; color: var(--ink3); line-height: 1.78;
}
.check-reveal.open { display: block; }
.check-reveal code {
  font-family: var(--mono); font-size: 12px; background: var(--bg2);
  padding: 1px 5px; border-radius: 3px; border: 1px solid var(--border);
}
.check-reveal strong { color: var(--ink); }
.check-reveal .answer-code {
  background: #181410; border-radius: 6px; padding: 14px 18px; margin: 10px 0;
  font-family: var(--mono); font-size: 12.5px; line-height: 1.7; overflow-x: auto;
  color: #abb2bf;
}

/* ─── RESOURCE CARDS ─── */
.res-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(250px,1fr));
  gap: 14px; margin-top: 28px;
}
.res-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 8px; padding: 18px; text-decoration: none;
  transition: all .2s; display: block;
}
.res-card:hover { border-color: var(--teal); transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.09); }
.res-card-type { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; margin-bottom: 7px; }
.res-card-name { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 6px; line-height: 1.4; }
.res-card-desc { font-size: 12px; color: var(--muted); line-height: 1.55; }

/* ─── SCHEDULE ─── */
.sched { display: flex; flex-direction: column; gap: 3px; margin-top: 22px; }
.sched-row {
  display: grid; grid-template-columns: 165px 1fr;
  background: var(--bg2); border: 1px solid var(--border); border-radius: 5px; overflow: hidden;
}
.sched-time {
  font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--teal);
  padding: 14px 16px; border-right: 1px solid var(--border); background: var(--teal-bg);
  display: flex; align-items: center;
}
.sched-desc { padding: 14px 18px; font-size: 14px; color: var(--ink3); line-height: 1.68; }
.sched-desc strong { color: var(--ink); }
.sched-desc code { font-family: var(--mono); font-size: 12px; background: var(--bg3); padding: 1px 5px; border-radius: 3px; border: 1px solid var(--border); }

/* ─── SPACED REPETITION CARDS ─── */
.recap-strip {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px; margin: 24px 0;
}
.recap-card {
  background: var(--bg2); border: 1px solid var(--border); border-radius: 8px;
  padding: 16px; border-top: 3px solid;
}
.recap-card.t { border-top-color: var(--teal); }
.recap-card.p { border-top-color: var(--plum); }
.recap-card.r { border-top-color: var(--rust); }
.recap-card.g { border-top-color: var(--gold); }
.recap-card h5 { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--muted2); margin-bottom: 8px; }
.recap-card p { font-size: 13px; color: var(--ink3); margin-bottom: 0; line-height: 1.6; }
.recap-card code { font-family: var(--mono); font-size: 11.5px; background: var(--bg3); padding: 1px 4px; border-radius: 3px; border: 1px solid var(--border); }

/* ─── TSCONFIG VISUAL ─── */
.tsconfig-visual {
  background: #181410; border-radius: 9px; padding: 28px;
  margin: 22px 0; border: 1px solid var(--border);
  font-family: var(--mono); font-size: 13px; line-height: 2;
}
.tc-key { color: #61afef; }
.tc-val-bool-true { color: #56b6c2; }
.tc-val-bool-false { color: #e06c75; }
.tc-val-str { color: #98c379; }
.tc-val-arr { color: #d19a66; }
.tc-comment { color: #5c6370; font-style: italic; }
.tc-bracket { color: #abb2bf; }
.tc-important { background: rgba(13,127,127,0.15); border-left: 2px solid var(--teal2); display: block; margin: 0 -28px; padding: 0 26px 0 26px; }
.tc-critical { background: rgba(192,57,43,0.12); border-left: 2px solid var(--rust2); display: block; margin: 0 -28px; padding: 0 26px 0 26px; }

.div { border: none; border-top: 1px solid var(--border); margin: 60px 0; }

/* ─── RESULT PATTERN VISUAL ─── */
.result-visual {
  display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin: 22px 0;
  border-radius: 9px; overflow: hidden; border: 1px solid var(--border);
  box-shadow: 0 3px 16px rgba(0,0,0,.06);
}
.rv-pane { padding: 0; }
.rv-head {
  padding: 10px 16px; font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase;
}
.rv-ok .rv-head { background: rgba(26,107,60,.1); color: var(--green); border-bottom: 1px solid rgba(26,107,60,.15); }
.rv-err .rv-head { background: rgba(192,57,43,.08); color: var(--rust); border-bottom: 1px solid rgba(192,57,43,.12); }
.rv-pane pre { border-radius: 0; font-size: 12.5px; padding: 20px; }

/* ─── FADE ANIMATIONS ─── */
.fade-in { animation: fadeIn .5s ease both; }
@keyframes fadeIn { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:none} }

@media (max-width: 900px) {
  .sidebar { display: none; }
  .main { margin-left: 0; }
  .content { padding: 40px 20px 80px; }
  .ba, .result-visual, .comp-grid { grid-template-columns: 1fr; }
  .sched-row { grid-template-columns: 1fr; }
  .flow { flex-direction: column; }
  .flow-arrow { display: none; }
}
</style>
</head>
