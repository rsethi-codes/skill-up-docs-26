<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Day 02 &mdash; Two Pointers &amp; Sliding Window | Raghav's DSA
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=JetBrains+Mono:ital,wght@0,300;0,400;0,700;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #f5f0e8;
        --bg2: #ede8de;
        --bg3: #e4ddd0;
        --bg4: #d8d0c4;
        --ink: #1a1410;
        --ink2: #2d2520;
        --ink3: #453d35;
        --muted: #7a6f62;
        --muted2: #a89e92;
        --border: rgba(26, 20, 16, 0.12);
        --border2: rgba(26, 20, 16, 0.07);
        --rust: #c0392b;
        --rust2: #e74c3c;
        --rust-bg: rgba(192, 57, 43, 0.07);
        --rust-border: rgba(192, 57, 43, 0.22);
        --teal: #0d7f7f;
        --teal-bg: rgba(13, 127, 127, 0.07);
        --teal-border: rgba(13, 127, 127, 0.22);
        --gold: #a07000;
        --gold-bg: rgba(160, 112, 0, 0.07);
        --gold-border: rgba(160, 112, 0, 0.22);
        --plum: #5b2d8e;
        --plum-bg: rgba(91, 45, 142, 0.07);
        --plum-border: rgba(91, 45, 142, 0.22);
        --green: #1a6b3c;
        --green-bg: rgba(26, 107, 60, 0.07);
        --green-border: rgba(26, 107, 60, 0.22);
        --serif: "Playfair Display", Georgia, serif;
        --mono: "JetBrains Mono", "Fira Code", monospace;
        --sans: "DM Sans", system-ui, sans-serif;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: var(--sans);
        background: var(--bg);
        color: var(--ink);
        line-height: 1.75;
        font-size: 16px;
        overflow-x: hidden;
      }
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.5;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");
      }
      #prog {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0;
        z-index: 1000;
        transition: width 0.08s linear;
        background: linear-gradient(
          90deg,
          var(--rust),
          var(--gold),
          var(--teal)
        );
        box-shadow: 0 0 8px rgba(192, 57, 43, 0.4);
      }
      #top-btn {
        position: fixed;
        bottom: 28px;
        right: 28px;
        width: 40px;
        height: 40px;
        background: var(--ink);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 18px;
        cursor: pointer;
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      #top-btn.show {
        opacity: 1;
      }
      .topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 54px;
        z-index: 900;
        background: rgba(245, 240, 232, 0.94);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 28px;
      }
      .tb-brand {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        color: var(--rust);
        letter-spacing: 0.07em;
      }
      .tb-day {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 0.04em;
      }
      .tb-nav {
        display: flex;
        gap: 22px;
        list-style: none;
      }
      .tb-nav a {
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.18s;
      }
      .tb-nav a:hover {
        color: var(--rust);
      }
      .sidebar {
        position: fixed;
        left: 0;
        top: 54px;
        width: 224px;
        height: calc(100vh - 54px);
        overflow-y: auto;
        padding: 22px 0;
        border-right: 1px solid var(--border);
        background: rgba(245, 240, 232, 0.85);
        backdrop-filter: blur(12px);
        z-index: 800;
      }
      .sidebar::-webkit-scrollbar {
        width: 2px;
      }
      .sidebar::-webkit-scrollbar-thumb {
        background: var(--muted2);
      }
      .toc-head {
        padding: 0 18px 10px;
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--muted2);
        border-bottom: 1px solid var(--border);
        margin-bottom: 8px;
      }
      .toc-link {
        display: block;
        padding: 5px 18px;
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 400;
        color: var(--muted);
        text-decoration: none;
        border-left: 2px solid transparent;
        transition: all 0.16s;
        line-height: 1.4;
      }
      .toc-link:hover,
      .toc-link.on {
        color: var(--rust);
        border-left-color: var(--rust);
        background: var(--rust-bg);
      }
      .toc-link.sub {
        padding-left: 30px;
        font-size: 11px;
      }
      .toc-link.sub:hover,
      .toc-link.sub.on {
        color: var(--teal);
        border-left-color: var(--teal);
        background: var(--teal-bg);
      }
      .main {
        margin-left: 224px;
        padding-top: 54px;
      }
      .content {
        max-width: 880px;
        margin: 0 auto;
        padding: 64px 44px 120px;
      }
      .hero {
        margin-bottom: 72px;
        padding-bottom: 56px;
        border-bottom: 2px solid var(--border);
      }
      .day-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--rust);
        color: #fff;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 4px 14px;
        border-radius: 2px;
        margin-bottom: 20px;
      }
      .day-pill::before {
        content: "";
        width: 5px;
        height: 5px;
        background: #fff;
        border-radius: 50%;
        animation: blink 2s ease-in-out infinite;
      }
      @keyframes blink {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.35;
          transform: scale(0.55);
        }
      }
      h1.hero-title {
        font-family: var(--serif);
        font-size: clamp(36px, 5.5vw, 64px);
        font-weight: 900;
        line-height: 1;
        letter-spacing: -0.025em;
        color: var(--ink);
        margin-bottom: 18px;
      }
      h1.hero-title em {
        color: var(--rust);
        font-style: italic;
      }
      .hero-lead {
        font-size: 17px;
        font-weight: 300;
        color: var(--ink3);
        max-width: 640px;
        line-height: 1.8;
        margin-bottom: 28px;
      }
      .hero-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }
      .tag {
        font-family: var(--mono);
        font-size: 10px;
        padding: 3px 10px;
        border-radius: 2px;
        border: 1px solid;
        letter-spacing: 0.04em;
      }
      .tag.r {
        color: var(--rust);
        border-color: var(--rust-border);
        background: var(--rust-bg);
      }
      .tag.t {
        color: var(--teal);
        border-color: var(--teal-border);
        background: var(--teal-bg);
      }
      .tag.g {
        color: var(--gold);
        border-color: var(--gold-border);
        background: var(--gold-bg);
      }
      .tag.p {
        color: var(--plum);
        border-color: var(--plum-border);
        background: var(--plum-bg);
      }
      .tag.gr {
        color: var(--green);
        border-color: var(--green-border);
        background: var(--green-bg);
      }
      .section {
        margin-bottom: 88px;
        scroll-margin-top: 74px;
      }
      .section-number {
        font-family: var(--mono);
        font-size: 9.5px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--muted2);
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .sn-label {
        letter-spacing: 0.04em;
        font-weight: 400;
      }
      .section-number::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      h2.sec-title {
        font-family: var(--serif);
        font-size: clamp(26px, 3.2vw, 40px);
        font-weight: 900;
        letter-spacing: -0.015em;
        line-height: 1.1;
        color: var(--ink);
        margin-bottom: 16px;
      }
      h2.sec-title em {
        color: var(--rust);
        font-style: italic;
      }
      .sec-lead {
        font-size: 15.5px;
        color: var(--ink3);
        max-width: 700px;
        margin-bottom: 40px;
        line-height: 1.8;
      }
      .sub {
        margin-bottom: 56px;
        scroll-margin-top: 74px;
      }
      h3.sub-title {
        font-family: var(--sans);
        font-size: 20px;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .sub-num {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        color: #fff;
        padding: 2px 8px;
        border-radius: 2px;
        flex-shrink: 0;
        background: var(--rust);
      }
      .sub-num.t {
        background: var(--teal);
      }
      .sub-num.g {
        background: var(--gold);
      }
      .sub-num.p {
        background: var(--plum);
      }
      .sub-num.gr {
        background: var(--green);
      }
      p.prose {
        color: var(--ink3);
        line-height: 1.82;
        margin-bottom: 18px;
        font-size: 15.5px;
      }
      p.prose strong {
        color: var(--ink);
        font-weight: 600;
      }
      p.prose em {
        color: var(--rust);
        font-style: italic;
      }
      p.prose code {
        font-family: var(--mono);
        font-size: 12.5px;
        background: var(--bg3);
        padding: 2px 6px;
        border-radius: 3px;
        color: var(--ink);
        border: 1px solid var(--border);
      }
      .callout {
        border-radius: 6px;
        padding: 18px 24px;
        margin: 24px 0;
        border-left: 3px solid;
      }
      .callout-title {
        font-family: var(--mono);
        font-size: 9.5px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 7px;
      }
      .callout p {
        margin-bottom: 0;
        font-size: 14.5px;
        line-height: 1.72;
        color: var(--ink3);
      }
      .callout p code {
        font-family: var(--mono);
        font-size: 12.5px;
        background: rgba(0, 0, 0, 0.06);
        padding: 1px 5px;
        border-radius: 3px;
      }
      .callout p strong {
        color: var(--ink);
      }
      .callout.danger {
        background: var(--rust-bg);
        border-color: var(--rust);
      }
      .callout.danger .callout-title {
        color: var(--rust);
      }
      .callout.insight {
        background: var(--plum-bg);
        border-color: var(--plum);
      }
      .callout.insight .callout-title {
        color: var(--plum);
      }
      .callout.tip {
        background: var(--green-bg);
        border-color: var(--green);
      }
      .callout.tip .callout-title {
        color: var(--green);
      }
      .callout.warn {
        background: var(--gold-bg);
        border-color: var(--gold);
      }
      .callout.warn .callout-title {
        color: var(--gold);
      }
      .callout.info {
        background: var(--teal-bg);
        border-color: var(--teal);
      }
      .callout.info .callout-title {
        color: var(--teal);
      }
      .code-block {
        border-radius: 8px;
        overflow: hidden;
        margin: 22px 0;
        border: 1px solid rgba(0, 0, 0, 0.18);
        box-shadow: 0 3px 16px rgba(0, 0, 0, 0.08);
      }
      .code-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 9px 16px;
        background: #1c1612;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }
      .code-lang {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
      }
      .code-label {
        font-family: var(--mono);
        font-size: 10.5px;
        color: rgba(255, 255, 255, 0.28);
        font-style: italic;
        flex: 1;
        text-align: center;
      }
      .copy-btn {
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.45);
        font-family: var(--mono);
        font-size: 10px;
        padding: 3px 9px;
        border-radius: 3px;
        cursor: pointer;
        transition: all 0.18s;
      }
      .copy-btn:hover {
        background: var(--rust);
        color: #fff;
        border-color: var(--rust);
      }
      pre {
        background: #1c1612;
        padding: 22px 26px;
        overflow-x: auto;
        font-family: var(--mono);
        font-size: 13px;
        line-height: 1.9;
      }
      pre code {
        background: none;
        padding: 0;
        color: #abb2bf;
      }
      .kw {
        color: #c678dd;
        font-weight: 500;
      }
      .fn {
        color: #61afef;
      }
      .st {
        color: #98c379;
      }
      .nu {
        color: #d19a66;
      }
      .cm {
        color: #5c6370;
        font-style: italic;
      }
      .py-bi {
        color: #e5c07b;
      }
      .diagram {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 28px;
        margin: 22px 0;
        overflow-x: auto;
      }
      .diag-title {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--muted);
        text-align: center;
        margin-bottom: 22px;
      }
      .diag-pre {
        background: transparent;
        color: var(--ink);
        padding: 0;
        font-family: var(--mono);
        font-size: 12.5px;
        line-height: 2;
        white-space: pre;
      }
      .mental-model {
        background: linear-gradient(135deg, var(--plum-bg), var(--teal-bg));
        border: 2px solid var(--plum-border);
        border-radius: 10px;
        padding: 28px 32px;
        margin: 28px 0;
      }
      .mental-model h4 {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--plum);
        margin-bottom: 14px;
      }
      .mental-model p {
        font-size: 16px;
        color: var(--ink);
        margin-bottom: 0;
        line-height: 1.78;
      }
      .mental-model p strong {
        color: var(--plum);
      }
      .mental-model p code {
        font-family: var(--mono);
        font-size: 13.5px;
        background: rgba(91, 45, 142, 0.1);
        padding: 2px 7px;
        border-radius: 3px;
      }
      .think-steps {
        border-radius: 10px;
        overflow: hidden;
        margin: 28px 0;
        border: 1px solid var(--border);
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
      }
      .think-step {
        padding: 22px 26px;
        border-bottom: 1px solid var(--border);
      }
      .think-step:last-child {
        border-bottom: none;
      }
      .think-step-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
        flex-wrap: wrap;
      }
      .think-step-num {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 3px;
        flex-shrink: 0;
      }
      .step-brute .think-step-num {
        background: rgba(192, 57, 43, 0.14);
        color: var(--rust);
      }
      .step-better .think-step-num {
        background: rgba(160, 112, 0, 0.14);
        color: var(--gold);
      }
      .step-optimal .think-step-num {
        background: rgba(26, 107, 60, 0.14);
        color: var(--green);
      }
      .step-brute {
        background: rgba(192, 57, 43, 0.025);
      }
      .step-better {
        background: rgba(160, 112, 0, 0.025);
      }
      .step-optimal {
        background: rgba(26, 107, 60, 0.025);
      }
      .think-step-title {
        font-family: var(--sans);
        font-size: 16px;
        font-weight: 600;
        color: var(--ink);
      }
      .think-step-complexity {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted);
        margin-left: auto;
      }
      .think-step-body {
        font-size: 14.5px;
        color: var(--ink3);
        line-height: 1.75;
        margin-bottom: 0;
      }
      .think-step-body code {
        font-family: var(--mono);
        font-size: 12.5px;
        background: rgba(0, 0, 0, 0.07);
        padding: 2px 6px;
        border-radius: 3px;
      }
      .think-step-body strong {
        color: var(--ink);
      }
      .think-step .code-block {
        margin: 14px 0 0;
      }
      .think-arrow {
        text-align: center;
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted2);
        padding: 8px;
        background: var(--bg3);
        border-bottom: 1px solid var(--border);
        letter-spacing: 0.06em;
      }
      .complexity-row {
        display: flex;
        gap: 12px;
        margin: 16px 0;
        flex-wrap: wrap;
      }
      .cb {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 5px 13px;
        border-radius: 4px;
        font-family: var(--mono);
        font-size: 12.5px;
        font-weight: 700;
        border: 1px solid;
      }
      .cb-label {
        font-weight: 400;
        opacity: 0.6;
        font-size: 10px;
      }
      .cb-time {
        background: var(--teal-bg);
        color: var(--teal);
        border-color: var(--teal-border);
      }
      .cb-space {
        background: var(--plum-bg);
        color: var(--plum);
        border-color: var(--plum-border);
      }
      .cb-bad {
        background: var(--rust-bg);
        color: var(--rust);
        border-color: var(--rust-border);
      }
      .cb-ok {
        background: var(--gold-bg);
        color: var(--gold);
        border-color: var(--gold-border);
      }
      .cb-good {
        background: var(--green-bg);
        color: var(--green);
        border-color: var(--green-border);
      }
      .video-wrap {
        margin: 28px 0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      }
      .video-label {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        background: var(--ink2);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
      }
      .video-label span {
        color: var(--rust2);
      }
      .video-wrap iframe {
        display: block;
        width: 100%;
        aspect-ratio: 16/9;
        border: none;
      }
      .lc-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin: 22px 0;
      }
      .lc-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 16px 18px;
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 7px;
        text-decoration: none;
        transition: all 0.18s;
      }
      .lc-row:hover {
        border-color: var(--rust);
        background: var(--rust-bg);
      }
      .lc-diff {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.07em;
        padding: 3px 8px;
        border-radius: 3px;
        flex-shrink: 0;
        margin-top: 2px;
      }
      .lc-easy {
        background: var(--green-bg);
        color: var(--green);
        border: 1px solid var(--green-border);
      }
      .lc-med {
        background: var(--gold-bg);
        color: var(--gold);
        border: 1px solid var(--gold-border);
      }
      .lc-body {
        flex: 1;
      }
      .lc-name {
        font-size: 14.5px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 4px;
      }
      .lc-why {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.55;
        margin-bottom: 6px;
      }
      .lc-hint {
        font-size: 12.5px;
        color: var(--teal);
        font-family: var(--mono);
        line-height: 1.5;
        background: var(--teal-bg);
        padding: 6px 10px;
        border-radius: 4px;
        border: 1px solid var(--teal-border);
      }
      .check-grid {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-top: 28px;
      }
      .check-item {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 20px 24px;
        transition: border-color 0.18s;
      }
      .check-item:hover {
        border-color: var(--rust);
      }
      .check-q {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--rust);
        margin-bottom: 8px;
      }
      .check-text {
        font-size: 15px;
        color: var(--ink);
        font-weight: 500;
        line-height: 1.65;
      }
      .check-reveal {
        margin-top: 14px;
        padding: 16px;
        background: var(--bg3);
        border-radius: 6px;
        font-size: 14px;
        color: var(--ink3);
        line-height: 1.78;
        display: none;
      }
      .check-reveal code {
        font-family: var(--mono);
        font-size: 12.5px;
        background: var(--bg2);
        padding: 1px 5px;
        border-radius: 3px;
        border: 1px solid var(--border);
      }
      .check-reveal strong {
        color: var(--ink);
      }
      .check-btn {
        margin-top: 12px;
        padding: 5px 13px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 3px;
        font-family: var(--mono);
        font-size: 10px;
        cursor: pointer;
        color: var(--muted);
        transition: all 0.18s;
      }
      .check-btn:hover {
        background: var(--rust);
        color: #fff;
        border-color: var(--rust);
      }
      .res-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
        gap: 14px;
        margin-top: 28px;
      }
      .res-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 18px;
        text-decoration: none;
        transition: all 0.2s;
        display: block;
      }
      .res-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 18px rgba(0, 0, 0, 0.09);
      }
      .res-card-type {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .res-card-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 6px;
      }
      .res-card-desc {
        font-size: 12px;
        color: var(--muted);
        line-height: 1.55;
      }
      .sched {
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-top: 22px;
      }
      .sched-row {
        display: grid;
        grid-template-columns: 130px 1fr;
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 5px;
        overflow: hidden;
      }
      .sched-time {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        color: var(--rust);
        padding: 14px 16px;
        border-right: 1px solid var(--border);
        background: var(--rust-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }
      .sched-desc {
        padding: 14px 18px;
        font-size: 14px;
        color: var(--ink3);
        line-height: 1.65;
      }
      .sched-desc strong {
        color: var(--ink);
      }
      .divider {
        border: none;
        border-top: 1px solid var(--border);
        margin: 64px 0;
      }
      .fade-up {
        animation: fadeUp 0.5s ease both;
      }
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(18px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      .closing-card {
        margin-top: 56px;
        padding: 40px;
        background: var(--bg2);
        border: 2px solid var(--border);
        border-radius: 12px;
        text-align: center;
      }
      .closing-card .day-num {
        font-family: var(--serif);
        font-size: 32px;
        font-weight: 900;
        color: var(--ink);
        margin-bottom: 8px;
      }
      .closing-card .closing-line {
        font-size: 16px;
        color: var(--muted);
        margin-bottom: 22px;
      }
      @media (max-width: 860px) {
        .sidebar {
          display: none;
        }
        .main {
          margin-left: 0;
        }
        .content {
          padding: 40px 20px 80px;
        }
        .sched-row {
          grid-template-columns: 1fr;
        }
        .think-step-complexity {
          margin-left: 0;
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
