              style="justify-content: center; margin-top: 16px"
            >
              <span class="tag r">Binary Search &rarr;</span
              ><span class="tag t">Rotated Array &rarr;</span
              ><span class="tag g">Search Space &rarr;</span
              ><span class="tag p">82 days to go</span>
            </div>
          </div>
        </section>
      </div>
    </main>
    <script>
      window.addEventListener("scroll", () => {
        const s = window.scrollY,
          t = document.body.scrollHeight - window.innerHeight;
        document.getElementById("prog").style.width = (s / t) * 100 + "%";
        document.getElementById("top-btn").classList.toggle("show", s > 400);
        let cur = "";
        document.querySelectorAll("[id]").forEach((el) => {
          if (window.scrollY >= el.offsetTop - 110) cur = el.id;
        });
        document
          .querySelectorAll(".toc-link")
          .forEach((l) =>
            l.classList.toggle("on", l.getAttribute("href") === "#" + cur),
          );
      });
      function copyCode(btn) {
        const pre = btn.closest(".code-block").querySelector("pre");
        navigator.clipboard.writeText(pre.innerText).then(() => {
          btn.textContent = "copied!";
          btn.style.cssText =
            "background:var(--green);color:#fff;border-color:var(--green)";
          setTimeout(() => {
            btn.textContent = "copy";
            btn.style.cssText = "";
          }, 2200);
        });
      }
      function revealAnswer(btn) {
        const r = btn.nextElementSibling,
          open = r.style.display === "block";
        r.style.display = open ? "none" : "block";
        btn.textContent = open ? "Reveal Answer" : "Hide Answer";
        btn.style.cssText = open
          ? ""
          : "background:var(--green);color:#fff;border-color:var(--green)";
      }
      const obs = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.style.cssText =
                "opacity:1;transform:none;transition:opacity .5s ease,transform .5s ease";
              obs.unobserve(e.target);
            }
          }),
        { threshold: 0.05 },
      );
      document
        .querySelectorAll(
          ".section,.sub,.think-steps,.mental-model,.diagram,.video-wrap",
        )
        .forEach((el) => {
          el.style.opacity = "0";
          el.style.transform = "translateY(16px)";
          obs.observe(el);
        });
    </script>
  </body>
</html>
